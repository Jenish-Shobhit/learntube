{
  "manifest_version": 3,
  "name": "LearnTube",
  "version": "1.0.0",
  "description": "Turns YouTube into a calm place to learn: a master on/off switch reclaims the masthead, removes Shorts and other distractions site-wide, and reshapes home and Subscriptions into a syllabus and a quiet inbox.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["subscriptions-list.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LearnTube",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
